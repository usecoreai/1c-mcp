{
  "mcpServers": {
    "1c-odata": {
      "command": "uv",
      "args": [
        "--directory",
        "{REPLACE_WITH_PATH_TO_FOLDER}",
        "run",                                                                                                 
        "python",
        "server.py"
      ],
      "env": {
        "ODATA_HOST": "",
        "ODATA_USER": "",
        "ODATA_PASS": "",
        "MCP_LOG_ENABLED": "true",
        "MCP_LOG_TELEMETRY_ENABLED": "true"
      }
    }
  }
}
